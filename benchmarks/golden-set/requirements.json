    {
      "id": "req-008",
      "text": "상품 목록 페이지에서 검색·필터·페이지네이션을 구현해줘. 검색은 제목+설명 full-text, 필터는 카테고리·가격 범위, 페이지당 20개.",
      "domain": "ecommerce",
      "ambiguityLevel": "low",
      "expectedResolutionRange": { "min": 0.68, "max": 0.88 }
    },
    {
      "id": "req-009",
