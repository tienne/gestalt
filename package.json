{
  "name": "@tienne/gestalt",
  "version": "0.31.0",
  "description": "TypeScript AI Development Harness - Gestalt psychology-driven requirement clarification",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "gestalt": "./dist/bin/gestalt.js"
  },
  "files": [
    "dist",
    "agents",
    "role-agents",
    "review-agents",
    "personas",
    "skills",
    "schemas",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx bin/gestalt.ts",
    "build": "tsc",
    "postbuild": "cp -r agents dist/ && cp -r role-agents dist/ && cp -r review-agents dist/ && cp -r personas dist/ && cp -r skills dist/ && cp -r schemas dist/ && cp package.json dist/ && chmod +x dist/bin/gestalt.js",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "tsx bin/gestalt.ts serve",
    "bench": "tsx benchmarks/run.ts",
    "resolution-bench": "tsx benchmarks/run-resolution-benchmark.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "version:sync": "tsx scripts/sync-version.ts",
    "postversion": "pnpm run version:sync"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.8.2",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "node-notifier": "^10.0.1",
    "node-pty": "^1.1.0",
    "open": "^11.0.0",
    "openai": "^6.27.0",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/node-notifier": "^8.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-pty",
      "onnxruntime-node",
      "sharp"
    ]
  }
}
