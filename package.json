{
  "name": "@tienne/gestalt",
  "version": "0.1.0",
  "description": "TypeScript AI Development Harness - Gestalt psychology-driven requirement clarification",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "gestalt": "./dist/bin/gestalt.js"
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin",
    ".mcp.json",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx bin/gestalt.ts",
    "build": "tsc",
    "postbuild": "cp -r skills dist/",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "tsx bin/gestalt.ts serve",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.2",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
