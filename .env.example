# ─── Anthropic API Key ───────────────────────────────────────────────────────
# Optional: Set to enable provider-backed mode (Interview, Spec, Resilience).
# Passthrough mode (default): No key needed — caller LLM (e.g. Claude Code) handles all generation.
# Execute Engine always runs in Passthrough mode regardless of this key.
ANTHROPIC_API_KEY=sk-ant-...

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Default model for all LLM calls (overridden per tier when tier config is present)
# GESTALT_MODEL=claude-sonnet-4-20250514

# Tier-level overrides — pattern: GESTALT_LLM_{TIER}_{FIELD}
# GESTALT_LLM_FRUGAL_PROVIDER=openai
# GESTALT_LLM_FRUGAL_API_KEY=ollama
# GESTALT_LLM_FRUGAL_BASE_URL=http://localhost:11434/v1
# GESTALT_LLM_FRUGAL_MODEL=llama3.2

# GESTALT_LLM_STANDARD_PROVIDER=anthropic
# GESTALT_LLM_STANDARD_API_KEY=
# GESTALT_LLM_STANDARD_BASE_URL=
# GESTALT_LLM_STANDARD_MODEL=claude-sonnet-4-20250514

# GESTALT_LLM_FRONTIER_PROVIDER=anthropic
# GESTALT_LLM_FRONTIER_API_KEY=
# GESTALT_LLM_FRONTIER_BASE_URL=
# GESTALT_LLM_FRONTIER_MODEL=claude-opus-4-20250514

# ─── Interview ────────────────────────────────────────────────────────────────
# Resolution score threshold to consider interview complete (0–1, default: 0.8)
# GESTALT_RESOLUTION_THRESHOLD=0.8

# Maximum number of interview rounds (default: 10)
# GESTALT_MAX_ROUNDS=10

# ─── Execute / Evolve ─────────────────────────────────────────────────────────
# Drift threshold — triggers Evolve loop when exceeded (0–1, default: 0.3)
# GESTALT_DRIFT_THRESHOLD=0.3

# Evolve success score threshold (0–1, default: 0.85)
# GESTALT_EVOLVE_SUCCESS_THRESHOLD=0.85

# Goal alignment minimum threshold (0–1, default: 0.80)
# GESTALT_EVOLVE_GOAL_ALIGNMENT_THRESHOLD=0.80

# ─── Storage & Directories ───────────────────────────────────────────────────
# SQLite event store path (default: ~/.gestalt/events.db)
# GESTALT_DB_PATH=.gestalt/events.db

# Skills directory (default: skills)
# GESTALT_SKILLS_DIR=skills

# Custom agents directory (default: agents)
# GESTALT_AGENTS_DIR=agents

# Role agents directory (default: role-agents)
# GESTALT_ROLE_AGENTS_DIR=role-agents

# Review agents directory (default: review-agents)
# GESTALT_REVIEW_AGENTS_DIR=review-agents

# ─── Misc ────────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error (default: info)
# GESTALT_LOG_LEVEL=info

# OS notification on completion/failure: true | false (default: false)
# GESTALT_NOTIFICATIONS=false

# Set to "1" to skip version update check
# GESTALT_NO_UPDATE_CHECK=1
