# Optional: Anthropic API key (provider-backed mode only, omit for passthrough mode)
# - Passthrough mode (default): No API key needed, caller LLM handles all generation
# - Provider-backed mode: Set this key to let Gestalt make direct LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override defaults
# GESTALT_MODEL=claude-sonnet-4-20250514
# GESTALT_AMBIGUITY_THRESHOLD=0.2
# GESTALT_MAX_ROUNDS=15
# GESTALT_DB_PATH=.gestalt/events.db
# GESTALT_SKILLS_DIR=skills
# GESTALT_LOG_LEVEL=info
